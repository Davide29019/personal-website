---
import { personalInfo, education, projects, skills } from '../data/portfolio.js';
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={personalInfo.tagline} />
    <title>{personalInfo.name} | {personalInfo.role}</title>
  </head>
  <body class="bg-slate-950 text-slate-100 font-sans antialiased selection:bg-cyan-500 selection:text-slate-950 min-h-screen">

    <div class="max-w-4xl mx-auto px-6 py-12 md:py-20 space-y-20">

      <!-- HERO SECTION -->
      <header class="space-y-6">
        <div class="inline-block px-3 py-1 rounded-full bg-cyan-950/80 border border-cyan-800/50 text-cyan-400 text-xs font-mono">
          📍 {personalInfo.location}
        </div>
        <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-white">
          Hi, I'm <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500">Davide</span>.
        </h1>
        <p class="text-xl md:text-2xl text-slate-300 font-light leading-relaxed max-w-2xl">
          {personalInfo.tagline}
        </p>
        <p class="text-slate-400 leading-relaxed max-w-2xl text-sm md:text-base">
          {personalInfo.about}
        </p>

        <!-- CTA BUTTONS -->
        <div class="flex flex-wrap gap-4 pt-2">
          <a href={personalInfo.socials.github} target="_blank" rel="noopener noreferrer"
             class="px-5 py-2.5 rounded-lg bg-slate-900 hover:bg-slate-800 text-slate-200 text-sm font-medium transition border border-slate-800">
            GitHub
          </a>
          <a href={personalInfo.socials.linkedin} target="_blank" rel="noopener noreferrer"
             class="px-5 py-2.5 rounded-lg bg-slate-900 hover:bg-slate-800 text-slate-200 text-sm font-medium transition border border-slate-800">
            LinkedIn
          </a>
          <!-- Email button con offuscamento via script -->
          <a id="email-btn" href="#"
             class="px-5 py-2.5 rounded-lg bg-slate-900 hover:bg-slate-800 text-slate-200 text-sm font-medium transition border border-slate-800 cursor-pointer">
            Email
          </a>
          <a href={personalInfo.socials.cvPdf} target="_blank"
             class="px-5 py-2.5 rounded-lg bg-cyan-500 hover:bg-cyan-400 text-slate-950 text-sm font-semibold transition">
            Download Resume (PDF)
          </a>
        </div>
      </header>

      <hr class="border-slate-800/80" />

      <!-- EDUCATION SECTION -->
      <section class="space-y-6">
        <h2 class="text-2xl font-bold text-white tracking-tight">Education</h2>
        <div class="space-y-4">
          {education.map((edu) => (
            <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 border-l-2 border-cyan-800/50 pl-4">
              <div>
                <h3 class="text-slate-100 font-semibold text-sm md:text-base">{edu.school}</h3>
                <p class="text-slate-400 text-xs md:text-sm">{edu.degree}</p>
              </div>
              <span class="text-slate-500 text-xs font-mono whitespace-nowrap">{edu.period}</span>
            </div>
          ))}
        </div>
      </section>

      <hr class="border-slate-800/80" />

      <!-- PROJECTS SECTION -->
      <section class="space-y-8">
        <div>
          <h2 class="text-2xl font-bold text-white tracking-tight">Featured Projects</h2>
          <p class="text-slate-400 text-sm mt-1">Technical implementations and engineering case studies.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {projects.map((project) => (
            <div class="p-6 rounded-xl bg-slate-900/40 border border-slate-800/80 hover:border-slate-700 transition flex flex-col justify-between space-y-4">
              <div class="space-y-3">
                <h3 class="text-lg font-semibold text-white">{project.title}</h3>
                <p class="text-slate-400 text-xs md:text-sm leading-relaxed">{project.description}</p>

                <ul class="list-disc list-inside text-xs text-slate-300 space-y-1.5">
                  {project.highlights.map((item) => (
                    <li class="leading-relaxed">{item}</li>
                  ))}
                </ul>
              </div>

              <div class="space-y-4 pt-2">
                <div class="flex flex-wrap gap-2">
                  {project.techStack.map((tech) => (
                    <span class="px-2.5 py-1 rounded bg-slate-800/80 text-cyan-300 text-xs font-mono border border-slate-700/50">
                      {tech}
                    </span>
                  ))}
                </div>

                <div class="flex gap-4 text-xs font-medium pt-2">
                  {project.githubUrl && (
                    <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="text-cyan-400 hover:underline">View Source &rarr;</a>
                  )}
                  {project.demoUrl && (
                    <a href={project.demoUrl} target="_blank" rel="noopener noreferrer" class="text-emerald-400 hover:underline">Live Demo &rarr;</a>
                  )}
                  {!project.githubUrl && !project.demoUrl && (
                    <span class="text-slate-600">Coursework project — code available on request</span>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <hr class="border-slate-800/80" />

      <!-- SKILLS SECTION -->
      <section class="space-y-8">
        <h2 class="text-2xl font-bold text-white tracking-tight">Technical Stack</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
          {skills.map((skillGroup) => (
            <div class="space-y-3">
              <h3 class="text-xs font-semibold text-slate-300 uppercase tracking-wider font-mono">{skillGroup.category}</h3>
              <ul class="space-y-2">
                {skillGroup.list.map((skill) => (
                  <li class="text-sm text-slate-400 flex items-center gap-2">
                    <span class="w-1.5 h-1.5 rounded-full bg-cyan-500"></span>
                    {skill}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>

      <!-- FOOTER -->
      <footer class="pt-12 text-center text-xs text-slate-500 border-t border-slate-900">
        <p>© {new Date().getFullYear()} {personalInfo.name}. Built with Astro & Tailwind. Hosted on Vercel.</p>
      </footer>

    </div>

    <!-- Script per comporre l'email solo lato client -->
    <script is:inline define:vars={{ u: personalInfo.socials.emailUser, d: personalInfo.socials.emailDomain }}>
      document.addEventListener('DOMContentLoaded', () => {
        const btn = document.getElementById('email-btn');
        if (btn) {
          btn.setAttribute('href', `mailto:${u}@${d}`);
        }
      });
    </script>
  </body>
</html>