---
import { personalInfo, projects, skills, currentlyExploring } from '../data/portfolio.js';
import '../styles/global.css';

const skillLabels = {
  core: "core & languages",
  ai_nlp_vision: "ai / nlp / vision",
  robotics: "robotics",
  tools: "tools & environment"
};
---

<div class="min-h-screen bg-[#14110B] text-[#C9C2B3] font-mono selection:bg-[#F2A65A] selection:text-[#14110B]">
  <div class="max-w-3xl mx-auto px-6 py-16 md:py-24 space-y-16">

    <!-- HERO / TERMINAL WINDOW -->
    <header class="rounded-lg border border-[#2A2620] bg-[#1A1712] overflow-hidden shadow-[0_0_40px_-15px_rgba(242,166,90,0.25)]">
      <div class="flex items-center gap-2 px-4 py-3 border-b border-[#2A2620] bg-[#1F1B15]">
        <span class="w-3 h-3 rounded-full bg-[#4a443a]"></span>
        <span class="w-3 h-3 rounded-full bg-[#4a443a]"></span>
        <span class="w-3 h-3 rounded-full bg-[#4a443a]"></span>
        <span class="ml-3 text-xs text-[#6b6457]">davide@portfolio: ~</span>
      </div>
      <div class="p-6 md:p-8 space-y-3 text-sm md:text-base leading-relaxed">
        <p><span class="text-[#7A9E7E]">$</span> whoami</p>
        <p class="text-2xl md:text-4xl font-bold text-[#F2E8D5] tracking-tight">{personalInfo.name}</p>
        <p class="text-[#F2A65A]">{personalInfo.tagline}</p>

        <p class="pt-4"><span class="text-[#7A9E7E]">$</span> cat about.txt</p>
        <p class="text-[#C9C2B3] max-w-xl">{personalInfo.about}</p>
        <p class="text-xs text-[#6b6457]">location: {personalInfo.location}</p>

        <p class="pt-4"><span class="text-[#7A9E7E]">$</span> open --links</p>
        <div class="flex flex-wrap gap-3 pt-1">
          <a href={personalInfo.socials.github} target="_blank" rel="noopener noreferrer"
             class="px-4 py-2 rounded border border-[#3a352c] hover:border-[#F2A65A] hover:text-[#F2A65A] text-xs transition">
            ./github
          </a>
          <a href={personalInfo.socials.linkedin} target="_blank" rel="noopener noreferrer"
             class="px-4 py-2 rounded border border-[#3a352c] hover:border-[#F2A65A] hover:text-[#F2A65A] text-xs transition">
            ./linkedin
          </a>
          <a href={personalInfo.socials.cvPdf} target="_blank"
             class="px-4 py-2 rounded bg-[#F2A65A] text-[#14110B] text-xs font-semibold hover:bg-[#f5b876] transition">
            ./resume.pdf
          </a>
        </div>
        <p class="pt-2 text-[#6b6457]">$ <span class="animate-pulse">▌</span></p>
      </div>
    </header>

    <!-- PROJECTS -->
    <section class="space-y-6">
      <p class="text-sm text-[#7A9E7E]">$ ls ~/projects --sort=featured</p>
      <div class="space-y-5">
        {projects.map((project) => (
          <div class="rounded-lg border border-[#2A2620] bg-[#1A1712] p-6 space-y-4 hover:border-[#3a352c] transition">
            <div class="space-y-2">
              <h3 class="text-[#F2E8D5] text-base md:text-lg font-semibold">{project.title}</h3>
              <p class="text-[#a89f8d] text-sm leading-relaxed">{project.description}</p>
            </div>

            <ul class="space-y-1.5">
              {project.highlights.map((item) => (
                <li class="text-xs md:text-sm text-[#C9C2B3] flex gap-2">
                  <span class="text-[#F2A65A] shrink-0">›</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>

            <div class="flex flex-wrap gap-2 pt-1">
              {project.techStack.map((tech) => (
                <span class="px-2 py-1 rounded bg-[#211D16] text-[#7A9E7E] text-xs border border-[#2A2620]">
                  {tech}
                </span>
              ))}
            </div>

            <div class="flex gap-4 text-xs font-medium pt-1">
              {project.githubUrl && (
                <a href={project.githubUrl} target="_blank" class="text-[#F2A65A] hover:underline">source →</a>
              )}
              {project.demoUrl && (
                <a href={project.demoUrl} target="_blank" class="text-[#7A9E7E] hover:underline">live demo →</a>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- SKILLS -->
    <section class="space-y-6">
      <p class="text-sm text-[#7A9E7E]">$ cat skills.json</p>
      <div class="rounded-lg border border-[#2A2620] bg-[#1A1712] p-6 grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-6">
        {skills.map((skillGroup) => (
          <div class="space-y-2">
            <p class="text-xs text-[#6b6457]">"{skillLabels[skillGroup.category] ?? skillGroup.category}":</p>
            <div class="flex flex-wrap gap-2 pl-2">
              {skillGroup.list.map((skill) => (
                <span class="text-sm text-[#F2E8D5]">{skill}<span class="text-[#4a443a]">,</span></span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- CURRENTLY EXPLORING -->
    <section class="space-y-6">
      <p class="text-sm text-[#7A9E7E]">$ tail -f currently_exploring.log</p>
      <div class="rounded-lg border border-[#2A2620] bg-[#1A1712] p-6 space-y-3">
        {currentlyExploring.map((item) => (
          <p class="text-sm text-[#C9C2B3] flex gap-2">
            <span class="text-[#F2A65A]">→</span>
            <span>{item}</span>
          </p>
        ))}
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="pt-8 text-center text-xs text-[#4a443a] border-t border-[#2A2620]">
      <p>$ echo "© {new Date().getFullYear()} {personalInfo.name} — built with Astro & Tailwind, hosted on Vercel"</p>
    </footer>

  </div>
</div>